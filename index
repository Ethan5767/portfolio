<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kimtong Peng | Portfolio</title>
  <style>
    :root {
      color-scheme: dark;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #05060a;
      color: #e7edf8;
      line-height: 1.6;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      overflow-x: hidden;
      background: radial-gradient(circle at top left, rgba(34, 111, 255, 0.18), transparent 28%),
        radial-gradient(circle at bottom right, rgba(110, 206, 255, 0.12), transparent 25%),
        linear-gradient(180deg, #05060a 0%, #090c16 55%, #05060a 100%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .page {
      max-width: 1080px;
      margin: 0 auto;
      padding: 28px 24px 80px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: 18px 0;
      position: sticky;
      top: 0;
      backdrop-filter: blur(18px);
      background: rgba(5, 6, 10, 0.7);
      z-index: 10;
    }

    .brand {
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 0.95rem;
      color: #8fcfff;
    }

    .nav-links {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      font-size: 0.96rem;
      opacity: 0.8;
    }

    .nav-links a {
      transition: opacity 0.25s ease;
    }

    .nav-links a:hover {
      opacity: 1;
    }

    .hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 42px 0 60px;
      position: relative;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background: radial-gradient(circle at center, rgba(143, 207, 255, 0.08), transparent 35%);
      opacity: 0.9;
      filter: blur(24px);
      pointer-events: none;
    }

    .hero-copy {
      max-width: 620px;
      animation: fadeInUp 0.9s ease both;
    }

    .hero-copy span {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #8fcfff;
      font-weight: 600;
      margin-bottom: 1.2rem;
    }

    .hero-copy h1 {
      font-size: clamp(2.7rem, 5vw, 4.6rem);
      letter-spacing: -0.05em;
      margin-bottom: 16px;
    }

    .hero-copy p {
      max-width: 600px;
      color: #c8d1e8;
      margin-bottom: 28px;
      font-size: 1.05rem;
    }

    .hero-meta {
      display: grid;
      gap: 12px;
    }

    .meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.07);
      max-width: fit-content;
      font-size: 0.96rem;
    }

    .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 14px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      border: none;
      border-radius: 999px;
      padding: 14px 22px;
      min-height: 48px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    }

    .button.primary {
      background: linear-gradient(135deg, #4f8dff, #6fdfff);
      color: #04101d;
      box-shadow: 0 18px 50px rgba(79, 141, 255, 0.14);
    }

    .button.secondary {
      background: rgba(255, 255, 255, 0.06);
      color: #d7e1f7;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .button:hover {
      transform: translateY(-2px);
    }

    .hero-visual {
      display: grid;
      justify-items: center;
      gap: 18px;
      animation: fadeInUp 1.1s ease both;
    }

    .hero-card {
      width: min(100%, 360px);
      border-radius: 28px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.20);
    }

    .hero-card img {
      width: 100%;
      display: block;
      aspect-ratio: 1 / 1;
      object-fit: cover;
    }

    .hero-card-body {
      padding: 24px;
    }

    .hero-card-body h2 {
      font-size: 1.45rem;
      margin-bottom: 10px;
    }

    .hero-card-body p {
      color: #abb7ce;
      font-size: 0.98rem;
      margin-bottom: 16px;
    }

    .hero-card-body .company {
      display: inline-flex;
      gap: 0.6rem;
      align-items: center;
      color: #8fcfff;
      font-weight: 600;
    }

    .section {
      padding: 46px 0;
      animation: fadeInUp 0.9s ease both;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
      font-size: 1.1rem;
      letter-spacing: 0.04em;
      color: #8fcfff;
      text-transform: uppercase;
    }

    .section-title::before {
      content: "";
      width: 56px;
      height: 1px;
      background: rgba(143, 207, 255, 0.28);
    }

    .grid {
      display: grid;
      gap: 18px;
    }

    .grid-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      padding: 24px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
      transition: transform 0.3s ease, border-color 0.3s ease;
    }

    .card:hover {
      transform: translateY(-6px);
      border-color: rgba(111, 223, 255, 0.35);
    }

    .card h3 {
      margin-bottom: 14px;
      font-size: 1.18rem;
      letter-spacing: -0.02em;
    }

    .card p,
    .card li {
      color: #c8d1e8;
      font-size: 0.98rem;
    }

    .card small {
      display: block;
      opacity: 0.75;
      margin-top: 0.65rem;
      font-size: 0.88rem;
    }

    .badge-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 12px;
    }

    .badge {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(79, 141, 255, 0.12);
      color: #b9d9ff;
      font-size: 0.88rem;
      border: 1px solid rgba(79, 141, 255, 0.16);
    }

    .skill-grid {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .timeline {
      display: grid;
      gap: 18px;
    }

    .timeline-item {
      padding: 18px 18px 18px 20px;
      border-left: 3px solid rgba(143, 207, 255, 0.4);
      position: relative;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 18px;
    }

    .timeline-item::before {
      content: "";
      position: absolute;
      left: -8px;
      top: 22px;
      width: 14px;
      height: 14px;
      background: #5ec6ff;
      border-radius: 50%;
      box-shadow: 0 0 0 6px rgba(94, 198, 255, 0.12);
    }

    .timeline-item h4 {
      font-size: 1rem;
      margin-bottom: 6px;
    }

    .timeline-item span {
      display: block;
      opacity: 0.75;
      margin-bottom: 12px;
      font-size: 0.9rem;
    }

    .footer {
      text-align: center;
      padding: 32px 0 12px;
      color: rgba(231, 237, 248, 0.7);
      font-size: 0.95rem;
    }

    .profile-pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 18px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      width: fit-content;
      margin-top: 18px;
    }

    .profile-pill img {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      object-fit: cover;
      border: 1px solid rgba(255, 255, 255, 0.12);
    }

    .cover {
      width: 100%;
      max-height: 230px;
      border-radius: 26px;
      overflow: hidden;
      margin-bottom: 24px;
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.16);
    }

    .cover img {
      width: 100%;
      height: auto;
      display: block;
      object-fit: cover;
    }

    @media (min-width: 840px) {
      .hero {
        grid-template-columns: 1.1fr 0.9fr;
      }

      .hero-copy {
        padding-right: 16px;
      }

      .hero-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .page {
        padding: 22px 18px 60px;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .hero-card {
        margin: 0 auto;
      }
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
